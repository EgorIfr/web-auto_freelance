---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import TopBanner from '../components/TopBanner.astro';
import Hero from '../components/Hero.astro';
import Advantages from '../components/Advantages.astro';
import Services from '../components/Services.astro';
import PriceList from '../components/PriceList.astro';
import Testimonials from '../components/Testimonials.astro';
import Footer from '../components/Footer.astro';
import CallModal from '../components/CallModal.astro';
import '../styles/global.css';
---

<Layout
  title="AutoElectric Service — Автоэлектрик в Краснодаре"
  description="Профессиональный автоэлектрик в Краснодаре. Компьютерная диагностика, ремонт электропроводки, установка сигнализаций. Выезд за 30 минут. Гарантия качества."
>
  <div class="relative flex min-h-screen w-full flex-col overflow-x-hidden">
    <Header />
    <TopBanner />
    <Hero />
    <Advantages />
    <Services />
    <PriceList />
    <Testimonials />
    <Footer />
    <CallModal />
  </div>
</Layout>
