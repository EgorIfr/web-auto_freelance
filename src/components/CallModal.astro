---
// Call Modal component - Fixed: added form validation (bug #8)
---

<dialog
  id="callModal"
  class="backdrop:bg-black/50 rounded-2xl p-0 max-w-md w-full"
>
  <div class="bg-white rounded-2xl p-6">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-2xl font-bold text-[#1c1c0d]">
        Заказать звонок
      </h3>
      <button
        onclick="document.getElementById('callModal').close()"
        class="size-10 flex items-center justify-center rounded-full hover:bg-gray-100 transition-colors"
        aria-label="Close"
      >
        <span class="material-symbols-outlined text-gray-600">
          close
        </span>
      </button>
    </div>
    
    <form id="callForm" class="flex flex-col gap-4">
      <div>
        <label
          for="name"
          class="block text-sm font-medium text-gray-700 mb-1"
        >
          Ваше имя
        </label>
        <input
          type="text"
          id="name"
          name="name"
          required
          minlength="2"
          class="w-full px-4 py-2 rounded-lg border border-gray-300 bg-white text-[#1c1c0d] focus:ring-2 focus:ring-primary focus:border-transparent"
          placeholder="Иван"
        />
      </div>
      
      <div>
        <label
          for="phone"
          class="block text-sm font-medium text-gray-700 mb-1"
        >
          Номер телефона
        </label>
        <input
          type="tel"
          id="phone"
          name="phone"
          required
          pattern="[0-9+\-\(\)\s]+"
          class="w-full px-4 py-2 rounded-lg border border-gray-300 bg-white text-[#1c1c0d] focus:ring-2 focus:ring-primary focus:border-transparent"
          placeholder="+7 (999) 123-45-67"
        />
      </div>
      
      <div>
        <label
          for="message"
          class="block text-sm font-medium text-gray-700 mb-1"
        >
          Комментарий (необязательно)
        </label>
        <textarea
          id="message"
          name="message"
          rows="3"
          class="w-full px-4 py-2 rounded-lg border border-gray-300 bg-white text-[#1c1c0d] focus:ring-2 focus:ring-primary focus:border-transparent resize-none"
          placeholder="Опишите вашу проблему..."
        ></textarea>
      </div>
      
      <button
        type="submit"
        id="callFormSubmit"
        class="w-full py-3 rounded-full bg-primary text-[#1c1c0d] font-bold hover:bg-orange-500 transition-colors shadow-sm flex items-center justify-center gap-2"
      >
        <span class="material-symbols-outlined text-xl">chat</span>
        Отправить через WhatsApp
      </button>
    </form>
    
    <p class="text-xs text-gray-500 text-center mt-4">
      Нажимая кнопку, вы соглашаетесь с политикой конфиденциальности
    </p>
  </div>
</dialog>

<script>
  // =========================================================
  // НАСТРОЙКА: Номер WhatsApp для получения заявок
  // Формат: 79991234567 (без +, без скобок, без дефиса)
  // =========================================================
  const WHATSAPP_NUMBER = '79991234567'; // ← ЗАМЕНИТЕ НА СВОЙ НОМЕР

  const form = document.getElementById('callForm') as HTMLFormElement;
  const modal = document.getElementById('callModal') as HTMLDialogElement;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const name = (formData.get('name') as string)?.trim() || 'Не указано';
    const phone = (formData.get('phone') as string)?.trim() || 'Не указан';
    const message = (formData.get('message') as string)?.trim();

    // Формируем сообщение для WhatsApp
    let waMessage = `🔧 *Новая заявка с сайта AutoElectric*%0A%0A`;
    waMessage += `👤 *Имя:* ${encodeURIComponent(name)}%0A`;
    waMessage += `📞 *Телефон:* ${encodeURIComponent(phone)}%0A`;
    if (message) {
      waMessage += `💬 *Комментарий:* ${encodeURIComponent(message)}%0A`;
    }
    waMessage += `%0A\u0412\u0440\u0435\u043c\u044f: ${encodeURIComponent(new Date().toLocaleString('ru-RU'))}`;

    // Открываем WhatsApp в новой вкладке
    window.open(`https://wa.me/${WHATSAPP_NUMBER}?text=${waMessage}`, '_blank');

    // Сбрасываем форму и закрываем модальное окно
    form.reset();
    modal?.close();
  });
</script>
