---
// Header component with navigation
const navLinks = [
  { href: '/', label: 'Главная' },
  { href: '/about', label: 'О компании' },
  { href: '/#services', label: 'Услуги' },
  { href: '/#contacts', label: 'Контакты' }
];
---

<header
  class="sticky top-0 z-50 flex w-full flex-col border-b border-solid border-b-[#e5e5e5] bg-white/95 backdrop-blur-sm"
>
  <div
    class="flex items-center justify-between whitespace-nowrap px-4 py-3 md:px-10 lg:px-40"
  >
    <div class="flex items-center gap-8">
      <a href="/" class="flex items-center gap-3 text-[#1c1c0d] hover:opacity-80 transition-opacity">
        <div
          class="flex items-center justify-center size-9 rounded-full text-black"
        >
          <span class="material-symbols-outlined">
            <img src="/images/services/electric-car.png" alt="">
          </span>
        </div>
        <h2
          class="text-lg font-bold leading-tight tracking-[-0.015em] hidden sm:block"
        >
          Автоэлектрик ГМР
        </h2>
      </a>
      
      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-6">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="text-sm font-medium text-[#1c1c0d] hover:text-primary transition-colors relative group"
          >
            {link.label}
            <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-primary transition-all group-hover:w-full"></span>
          </a>
        ))}
      </nav>
    </div>
    
    <div class="flex items-center gap-2 sm:gap-4">
      <a
        class="hidden md:block text-sm font-bold leading-normal tracking-[0.015em] hover:text-primary transition-colors"
        href="tel:+79991234567"
      >
        +7 (938) 520-16-16
      </a>
      
      <a
        class="flex size-8 cursor-pointer items-center justify-center rounded-full bg-[#f4f4e6] hover:bg-primary/20 transition-colors"
        href="https://wa.me/79991234567"
        aria-label="WhatsApp"
      >
        <span class="material-symbols-outlined text-[#1c1c0d]">
          <img src="/images/services/whatsapp.svg" alt="">
        </span>
      </a>
      
      <!-- Mobile menu button -->
      <button
        id="mobileMenuBtn"
        class="flex lg:hidden size-10 items-center justify-center rounded-full hover:bg-[#f4f4e6] transition-colors"
        aria-label="Menu"
      >
        <span class="material-symbols-outlined text-[#1c1c0d]">
          menu
        </span>
      </button>
      
      <button
        onclick="document.getElementById('callModal').showModal()"
        class="hidden sm:flex h-10 cursor-pointer items-center justify-center overflow-hidden rounded-full bg-primary px-4 text-[#1c1c0d] text-sm font-bold leading-normal tracking-[0.015em] hover:bg-orange-500 transition-colors shadow-sm"
      >
        <span class="truncate">Заказать звонок</span>
      </button>
    </div>
  </div>
  
  <!-- Mobile Navigation Menu -->
  <nav
    id="mobileMenu"
    class="hidden lg:hidden flex-col gap-2 px-4 pb-4 border-t border-[#e5e5e5] animate-fade-in-up"
  >
    {navLinks.map(link => (
      <a
        href={link.href}
        class="mobile-nav-link px-4 py-3 rounded-lg text-sm font-medium text-[#1c1c0d] hover:bg-primary/10 hover:text-primary transition-all"
      >
        {link.label}
      </a>
    ))}
    <button
      onclick="document.getElementById('callModal').showModal()"
      class="sm:hidden mt-2 flex h-12 cursor-pointer items-center justify-center rounded-full bg-primary px-4 text-[#1c1c0d] text-sm font-bold leading-normal tracking-[0.015em] hover:bg-orange-500 transition-colors shadow-sm"
    >
      <span class="truncate">Заказать звонок</span>
    </button>
  </nav>
</header>

<script>
  const mobileMenuBtn = document.getElementById('mobileMenuBtn');
  const mobileMenu = document.getElementById('mobileMenu');
  
  if (mobileMenuBtn && mobileMenu) {
    mobileMenuBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
      const icon = mobileMenuBtn.querySelector('.material-symbols-outlined');
      if (icon) {
        icon.textContent = mobileMenu.classList.contains('hidden') ? 'menu' : 'close';
      }
    });
    
    // Close menu when clicking on a link
    const mobileNavLinks = document.querySelectorAll('.mobile-nav-link');
    mobileNavLinks.forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
        const icon = mobileMenuBtn.querySelector('.material-symbols-outlined');
        if (icon) {
          icon.textContent = 'menu';
        }
      });
    });
  }
</script>
