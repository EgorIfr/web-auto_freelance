---
// Services section component
import { getServices, getFeaturedImage } from '../lib/wordpress';

// =========================================================
// ИНСТРУКЦИЯ ДЛЯ КЛИЕНТА: Фотографии услуг
// =========================================================
// Создайте папку: /public/images/services/
// Поместите туда следующие фотографии (размер 800x533px, JPG/WebP):
//
//  service-1-diagnostics.jpg   — Компьютерная диагностика
//                                 (пример: ноутбук + сканер подключен к авто)
//
//  service-2-alarm.jpg         — Установка автосигнализации
//                                 (пример: брелок сигнализации, монтаж)
//
//  service-3-ac.jpg            — Заправка кондиционеров
//                                 (пример: заправка фреоном, манометры)
//
//  service-4-audio.jpg         — Аудио/Мультимедиа
//                                 (пример: автомагнитола, колонки, установка)
//
//  service-5-wiring.jpg        — Ремонт проводки
//                                 (пример: руки мастера с проводкой)
//
//  service-6-generator.jpg     — Генератор/Стартер/Бензонасос
//                                 (пример: генератор двигателя)
//
//  service-7-start.jpg         — Запуск двигателя
//                                 (пример: прикуривание аккумулятора)
//
//  service-8-battery.jpg       — Обслуживание аккумулятора
//                                 (пример: проверка АКБ мультиметром)
// =========================================================

const defaultServices = [
  {
    title: 'Компьютерная диагностика',
    price: 'от 800₽',
    description: 'Чтение и сброс ошибок, адаптация блоков, проверка датчиков.',
    // ФОТО: /public/images/services/service-1-diagnostics.jpg
    image: '/images/services/service-1-diagnostics.jpg',
    alt: 'Компьютерная диагностика автомобиля — сканер подключен к бортовому компьютеру'
  },
  {
    title: 'Установка и демонтаж автосигнализации',
    price: 'от 3000₽',
    description: 'Монтаж и демонтаж охранных систем, автозапуск, GPS-трекеры, парктроники.',
    // ФОТО: /public/images/services/service-2-alarm.jpg
    image: '/images/services/service-2-alarm.jpg',
    alt: 'Установка автосигнализации — брелок и компоненты охранной системы'
  },
  {
    title: 'Заправка автокондиционеров',
    price: 'от 1200₽',
    description: 'Диагностика системы кондиционирования, заправка фреоном, ремонт электрической части.',
    // ФОТО: /public/images/services/service-3-ac.jpg
    image: '/images/services/service-3-ac.jpg',
    alt: 'Заправка автокондиционера фреоном — диагностика и обслуживание'
  },
  {
    title: 'Установка аудио, видео, мультимедиа',
    price: 'от 2000₽',
    description: 'Установка автозвука, магнитол, усилителей, сабвуферов, камер заднего вида.',
    // ФОТО: /public/images/services/service-4-audio.jpg
    image: '/images/services/service-4-audio.jpg',
    alt: 'Установка автозвука и мультимедиа — магнитола, усилитель, сабвуфер'
  },
  {
    title: 'Ремонт, восстановление электропроводки',
    price: 'от 1500₽',
    description: 'Поиск обрывов, замыканий, восстановление косы, замена разъемов.',
    // ФОТО: /public/images/services/service-5-wiring.jpg
    image: '/images/services/service-5-wiring.jpg',
    alt: 'Ремонт электропроводки автомобиля — поиск и устранение замыканий'
  },
  {
    title: 'Ремонт и замена генератора, стартера, бензонасоса',
    price: 'от 1500₽',
    description: 'Диагностика и ремонт генератора, стартера, замена бензонасоса, форсунок.',
    // ФОТО: /public/images/services/service-6-generator.jpg
    image: '/images/services/service-6-generator.jpg',
    alt: 'Ремонт генератора и стартера — замена и восстановление'
  },
  {
    title: 'Запуск двигателя автомобиля',
    price: 'от 1000₽',
    description: 'Экстренный запуск двигателя, диагностика и устранение причин незапуска.',
    // ФОТО: /public/images/services/service-7-start.jpg
    image: '/images/services/service-7-start.jpg',
    alt: 'Экстренный запуск двигателя — прикуривание и диагностика'
  },
  {
    title: 'Обслуживание аккумулятора',
    price: 'от 500₽',
    description: 'Проверка емкости, поиск утечек тока, зарядка и замена АКБ.',
    // ФОТО: /public/images/services/service-8-battery.jpg
    image: '/images/services/service-8-battery.jpg',
    alt: 'Обслуживание аккумулятора — проверка мультиметром и замена АКБ'
  }
];

const wpServices = await getServices();

const services = wpServices.length > 0 ? wpServices.map(post => ({
  title: post.title.rendered,
  price: post.acf?.price || '',
  description: post.acf?.short_description || post.excerpt.rendered.replace(/<[^>]+>/g, ''),
  image: getFeaturedImage(post),
  alt: post.title.rendered
})) : defaultServices;
---

<div
  id="services"
  class="flex flex-col items-center px-4 py-16 md:px-10 lg:px-40 bg-background-light"
>
  <div class="flex w-full max-w-[1200px] flex-col gap-10">
    <div class="flex items-center justify-between">
      <h2
        class="text-[#1c1c0d] text-3xl font-black leading-tight tracking-[-0.015em] md:text-4xl"
      >
        Услуги
      </h2>
      <button
        class="hidden sm:flex text-sm font-bold underline decoration-primary decoration-2 underline-offset-4 hover:text-gray-600 transition-colors"
      >
        Все услуги
      </button>
    </div>
    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      {services.map((service) => (
        <div
          class="flex flex-col rounded-xl bg-white p-4 shadow-sm transition-all hover:shadow-md hover:-translate-y-1 group"
        >
          <div
            class="flex flex-col items-stretch gap-4 sm:flex-row sm:items-start"
          >
            <div
              class="aspect-video w-full rounded-lg bg-cover bg-center sm:w-1/3 relative overflow-hidden"
              role="img"
              aria-label={service.alt}
              style={service.image ? `background-image: url('${service.image}');` : ''}
            >
              {!service.image && (
                <div class="absolute inset-0 bg-gradient-to-br from-gray-100 to-gray-200 flex flex-col items-center justify-center gap-2">
                  <span class="material-symbols-outlined text-3xl text-gray-400">image</span>
                  <span class="text-xs text-gray-400 font-medium">Фото скоро</span>
                </div>
              )}
            </div>
            <div class="flex flex-1 flex-col justify-between gap-3 py-1">
              <div>
                <div class="mb-2 flex items-center justify-between">
                  <span
                    class="rounded-full bg-primary/20 px-3 py-1 text-xs font-bold text-black"
                  >
                    {service.price}
                  </span>
                </div>
                <h3 class="text-xl font-bold text-[#1c1c0d]">
                  {service.title}
                </h3>
                <p class="mt-2 text-sm text-[#666]">
                  {service.description}
                </p>
              </div>
              <button
                onclick="document.getElementById('callModal').showModal()"
                class="mt-2 flex w-full items-center justify-center rounded-full bg-background-light py-2 text-sm font-bold transition-colors group-hover:bg-primary group-hover:text-black"
              >
                Подробнее
              </button>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>
